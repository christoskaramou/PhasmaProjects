# Python/editor scratch
__pycache__/
*.py[cod]

# Local hi-res texture upgrades (fetch/regenerate locally)
*/Assets/Textures/Solar/8k_*
*/Assets/Textures/Solar/*.exr

# Phasma editor/runtime state, written into the active project.
*/Assets/editor_config.json
*/Assets/editor_windows.json
*/Assets/imgui.ini
*/Assets/Save/

# Local AI/agent runtime artifacts. Keep checked-in config, ignore session output.
*/Assets/Agent/image_*.png
*/Assets/Agent/sessions/
*/Assets/Agent/*.log
*/Assets/Agent/ss_*.png
*/Assets/HeroBrain/requests/
*/Assets/HeroBrain/responses/

# Engine binaries may be dropped beside a project for quick local runs.
*/PhasmaLauncher.exe
*/PhasmaPlayer.exe
*/PhasmaEditor.exe
*/PhasmaCore.dll
*/PhasmaEditorModule_*.dll
*/PhasmaEngine.log

# One-off capture/probe output from local playtests.
*/arena_cap_screen*.png
*/arena_probe.png
