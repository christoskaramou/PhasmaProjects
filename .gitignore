# Editor session state (written into project Assets when the project is active)
Assets/editor_config.json

__pycache__/

# Editor runtime state
Assets/editor_windows.json
Assets/imgui.ini
Assets/Save/

# Agent/MCP runtime artifacts (screenshots, session logs) — config stays tracked
Assets/Agent/image_*.png
Assets/Agent/sessions/
Assets/Agent/*.log
Assets/Agent/ss_*.png
